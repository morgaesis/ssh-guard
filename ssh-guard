#!/usr/bin/env bash
# ssh-guard: SSH wrapper that sends commands to an LLM for approval before execution.
# Designed for AI agents that need SSH access but shouldn't run destructive commands.
#
# Usage:
#   ssh-guard <ssh-args>          # same interface as ssh
#   ssh-guard user@host "ls -la"  # command gets reviewed by LLM before execution
#
# Environment variables (set directly or in .env files):
#   SSH_GUARD_API_URL     - LLM API endpoint (default: https://openrouter.ai/api/v1/chat/completions)
#   SSH_GUARD_API_KEY     - API key for the LLM endpoint (required; OPENROUTER_API_KEY also works)
#   SSH_GUARD_MODEL       - Model to use (default: google/gemini-2.0-flash-001)
#   SSH_GUARD_PROMPT      - System prompt for the LLM judge
#   SSH_GUARD_SSH_BIN     - Path to real ssh binary (default: /usr/bin/ssh)
#   SSH_GUARD_API_TYPE    - API type: "openai" or "anthropic" (default: openai)
#   SSH_GUARD_LOG         - Log file path (default: none)
#   SSH_GUARD_PASSTHROUGH - Comma-separated commands to always allow without LLM check
#   SSH_GUARD_MAX_TOKENS  - Max tokens for LLM response (default: 512)
#   SSH_GUARD_MODE        - Policy mode: "readonly", "paranoid", or "safe" (default: readonly)
#   SSH_GUARD_TIMEOUT     - Curl timeout in seconds for LLM call (default: 30)
#   SSH_GUARD_REDACT      - Redact secrets from output: "true" or "false" (default: true)

set -euo pipefail

# --- .env sourcing: walk up from CWD to / ---
_source_env_files() {
  local dir="$PWD"
  local envfiles=()
  while true; do
    [[ -f "$dir/.env" ]] && envfiles+=("$dir/.env")
    [[ "$dir" == "/" ]] && break
    dir="$(dirname "$dir")"
  done
  # Source in reverse order so closest .env wins
  for ((i = ${#envfiles[@]} - 1; i >= 0; i--)); do
    set -a
    # shellcheck disable=SC1090
    source "${envfiles[$i]}" 2>/dev/null || true
    set +a
  done
}
_source_env_files

# --- Configuration ---
SSH_BIN="${SSH_GUARD_SSH_BIN:-/usr/bin/ssh}"
API_URL="${SSH_GUARD_API_URL:-https://openrouter.ai/api/v1/chat/completions}"
API_KEY="${SSH_GUARD_API_KEY:-${OPENROUTER_API_KEY:-}}"
MODEL="${SSH_GUARD_MODEL:-google/gemini-2.0-flash-001}"
API_TYPE="${SSH_GUARD_API_TYPE:-openai}"
MAX_TOKENS="${SSH_GUARD_MAX_TOKENS:-512}"
TIMEOUT="${SSH_GUARD_TIMEOUT:-30}"
LOG="${SSH_GUARD_LOG:-}"
PASSTHROUGH="${SSH_GUARD_PASSTHROUGH:-}"
MODE="${SSH_GUARD_MODE:-readonly}"
REDACT="${SSH_GUARD_REDACT:-true}"

# --- Mode prompts ---
# Each mode defines a system prompt for the LLM judge.
# SSH_GUARD_PROMPT overrides all modes if set.

PROMPT_SUFFIX='
For chained commands (&&, ;, |), evaluate EACH part independently. If ANY part violates the policy, DENY the whole command.

Respond with EXACTLY this JSON format, no other text:
{"decision": "APPROVE" or "DENY", "reason": "brief explanation"}'

# shellcheck disable=SC2016
PROMPT_READONLY='You are a security gate for SSH commands on remote servers, enforcing a READ-ONLY policy.

APPROVE commands that only read or query:
- Read files/logs/config (cat, less, head, tail, grep, find, ls, stat, file, wc, diff, md5sum, sha256sum)
- Query system state (uptime, df, free, ps, top, who, w, id, hostname, uname, ip, ss, netstat, lsblk, mount)
- Query services read-only (systemctl status, journalctl, docker ps, docker logs, docker inspect, kubectl get/describe/logs)
- Read package info (dpkg -l, rpm -qa, apt list, pip list, snap list)
- Print environment metadata (printenv, env, echo $VAR, locale, timedatectl status)

DENY commands that modify anything:
- Write/move/delete files (rm, mv, cp, tee, dd, chmod, chown, truncate, shred, touch, mkdir, ln, editors)
- Package management (apt install/remove/upgrade, yum, dnf, pip install, npm install, cargo install)
- Service/process management (systemctl start/stop/restart/enable/disable, kill, killall, reboot, shutdown, init)
- System config changes (usermod, useradd, userdel, visudo, iptables, firewall-cmd, sysctl -w, crontab -e)
- Container/orchestration writes (docker run/stop/rm/exec/build, kubectl apply/delete/edit/scale/rollout/patch)
- Shells/interpreters (bash -c, python -c, eval, exec, nohup, screen, tmux new)
- Output redirection into files (>, >>, | tee)
- Unrestricted privilege escalation (su, doas, pkexec)
- Remote code execution (curl|bash, wget+chmod)
- Tunneling/forwarding (ssh -L/-R/-D, socat, nc -l)

sudo handling: sudo is NOT automatically denied. Evaluate the command AFTER sudo the same way you would without it.
- "sudo ls /etc/nginx/" -> the actual command is "ls /etc/nginx/" which is read-only -> APPROVE
- "sudo cat /var/log/syslog" -> read-only -> APPROVE
- "sudo rm -rf /etc/nginx/" -> modifies files -> DENY
- "sudo systemctl restart nginx" -> modifies service state -> DENY
Strip "sudo" (and sudo flags like -u, -E, -H) and evaluate the underlying command against the policy above.'

# shellcheck disable=SC2016
PROMPT_PARANOID='You are a security gate for SSH commands on remote servers, enforcing a PARANOID policy.
The goal is read-only access with ZERO data exfiltration risk. Be extremely conservative.

APPROVE commands that show only structural/operational metadata:
- List files/dirs without reading content (ls, find -name, find -type, stat, file, du, tree)
- System identity and resource usage (uptime, df, free, hostname, uname, lsblk, lscpu, nproc, arch)
- Process listing (ps aux, top -bn1, pgrep)
- Network structure without payload (ip addr, ip route, ss -tlnp, netstat -tlnp)
- Service status without logs (systemctl status, systemctl list-units, docker ps, kubectl get pods/nodes/services)

DENY commands that could leak secrets or sensitive data:
- Reading file contents (cat, less, head, tail, strings, xxd, od, base64) -- these could expose credentials, keys, tokens
- Printing environment variables (printenv, env, echo $VAR, set) -- these often contain API keys and secrets
- Reading logs (journalctl, docker logs, kubectl logs, tail -f /var/log/*) -- logs may contain tokens, passwords, PII
- Package details beyond listing (pip show, npm info, dpkg -L)
- Dumping configuration (cat /etc/*, sysctl -a, iptables -L with details)
- Anything that reads database content (psql, mysql, mongo, redis-cli, sqlite3)
- Any network data capture (tcpdump, tshark, strace, ltrace, ngrep)
- Reading SSH/TLS material (cat ~/.ssh/*, cat /etc/ssl/*, openssl)
- History commands (history, cat .*_history)
- AND everything the read-only policy would deny (writes, installs, service changes, etc.)

sudo handling: sudo is NOT automatically denied. Strip "sudo" (and sudo flags like -u, -E, -H) and evaluate the underlying command.
- "sudo ls /root/" -> structural listing -> APPROVE
- "sudo cat /etc/shadow" -> reads sensitive file contents -> DENY
- "sudo printenv" -> leaks env vars -> DENY

When in doubt, DENY. The cost of a false deny is a retry; the cost of a leak is a breach.'

# shellcheck disable=SC2016
PROMPT_SAFE='You are a security gate for SSH commands on remote servers, enforcing a SAFE-OPS policy.
The goal is to allow normal operational work but block dangerous, destructive, or irreversible actions.

APPROVE commands that are safe operational work:
- All read operations (cat, ls, grep, find, tail, head, less, journalctl, docker logs, kubectl logs, etc.)
- Safe file writes (tee, cp, mkdir -p, touch, echo > for config files, scp)
- Service restarts with limited blast radius (systemctl restart <specific-service>, docker restart <container>)
- Package queries and installs of specific packages (apt install <pkg>, pip install <pkg>, npm install <pkg>)
- Container operations on specific named targets (docker exec, docker run with explicit image, kubectl exec)
- Git operations (git pull, git checkout, git clone)
- Text processing and scripting (awk, sed, python -c for data processing)
- Cron and scheduled task viewing/editing (crontab -l, crontab -e)

DENY commands that are destructive, irreversible, or reckless:
- Mass deletion or recursive removal (rm -rf, find -delete on broad paths, shred)
- Disk/partition operations (dd, fdisk, mkfs, mount/umount, wipefs, parted)
- Broad privilege operations (chmod -R 777, chown -R on system dirs)
- System-wide state changes (reboot, shutdown, init 0/6, halt, poweroff)
- Mass service disruption (systemctl stop on critical services like sshd/networking/docker, killall, kill -9 1)
- Unscoped package operations (apt upgrade, apt dist-upgrade, pip install --upgrade without specific package)
- Destructive container/k8s operations (docker system prune, kubectl delete namespace, kubectl delete --all)
- Database destructive operations (DROP TABLE/DATABASE, TRUNCATE, DELETE without WHERE)
- Network reconfiguration that could lock you out (iptables -F, ufw reset, ip link set down on primary interface)
- Downloading and executing unverified code (curl|bash, wget|sh from untrusted sources)
- Kernel/bootloader modifications (modprobe, grub-install, update-grub with unusual params)
- Security-sensitive changes (passwd, usermod -G, visudo, editing /etc/shadow or /etc/sudoers directly)

sudo handling: sudo is NOT automatically denied. Strip "sudo" (and sudo flags like -u, -E, -H) and evaluate the underlying command.
- "sudo ls -lah /etc/nginx/" -> targeted read -> APPROVE
- "sudo systemctl restart myapp" -> scoped service restart -> APPROVE
- "sudo rm -rf /etc/nginx/" -> destructive removal -> DENY
- "sudo chmod -R 777 /" -> reckless broad permission change -> DENY

Key principle: targeted operations on specific resources are OK. Broad, recursive, or system-wide destructive operations are not.'

# --- Resolve prompt ---
_resolve_prompt() {
  # Explicit override takes priority
  if [[ -n "${SSH_GUARD_PROMPT:-}" ]]; then
    echo "$SSH_GUARD_PROMPT"
    return
  fi

  local base
  case "$MODE" in
    readonly) base="$PROMPT_READONLY" ;;
    paranoid) base="$PROMPT_PARANOID" ;;
    safe) base="$PROMPT_SAFE" ;;
    *)
      echo "ssh-guard: unknown mode '$MODE'. Use: readonly, paranoid, safe" >&2
      exit 1
      ;;
  esac
  echo "${base}${PROMPT_SUFFIX}"
}

SYSTEM_PROMPT="$(_resolve_prompt)"

# --- Logging ---
_log() {
  if [[ -n "$LOG" ]]; then
    echo "[$(date -Iseconds)] $*" >>"$LOG"
  fi
}

# --- Parse SSH arguments to extract the remote command ---
# SSH syntax: ssh [options] destination [command [argument ...]]
# We need to find the command portion after the destination.
_extract_command() {
  local -a opts_with_arg=(-b -c -D -E -e -F -I -i -J -L -l -m -O -o -p -Q -R -S -W -w)
  local found_destination=false
  local -a cmd_parts=()
  local skip_next=false

  for arg in "$@"; do
    if $skip_next; then
      skip_next=false
      continue
    fi

    # Check if this is an option that takes an argument
    local is_opt_with_arg=false
    for opt in "${opts_with_arg[@]}"; do
      if [[ "$arg" == "$opt" ]]; then
        is_opt_with_arg=true
        skip_next=true
        break
      fi
      # Handle -oValue (option+value concatenated)
      if [[ "$arg" == "${opt}"* && ${#arg} -gt 2 ]]; then
        is_opt_with_arg=true
        break
      fi
    done
    $is_opt_with_arg && continue

    # Skip standalone flags (single dash + letters, no argument)
    if [[ "$arg" == -* ]]; then
      continue
    fi

    # First non-option is destination, rest is the command
    if ! $found_destination; then
      found_destination=true
      continue
    fi

    cmd_parts+=("$arg")
  done

  echo "${cmd_parts[*]}"
}

# --- Check passthrough list ---
_is_passthrough() {
  local cmd="$1"
  [[ -z "$PASSTHROUGH" ]] && return 1
  local base_cmd="${cmd%% *}"
  IFS=',' read -ra allowed <<<"$PASSTHROUGH"
  for a in "${allowed[@]}"; do
    a="${a## }"
    a="${a%% }" # trim whitespace
    [[ "$base_cmd" == "$a" ]] && return 0
  done
  return 1
}

# --- Tool/function definition for structured responses ---
# Shared schema, rendered per API type in _call_llm.
TOOL_NAME="ssh_command_decision"
TOOL_DESC="Approve or deny an SSH command based on the security policy."
# shellcheck disable=SC2016
TOOL_SCHEMA='{
  "type": "object",
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["APPROVE", "DENY"],
      "description": "Whether to allow the command to execute."
    },
    "reason": {
      "type": "string",
      "description": "Brief explanation for the decision."
    },
    "risk": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10,
      "description": "Risk score 0-10. 0=harmless read, 5=moderate side effects, 10=catastrophic/irreversible."
    }
  },
  "required": ["decision", "reason", "risk"]
}'

# --- Call LLM for approval ---
_call_llm() {
  local command="$1"
  local host="$2"
  local user_message="Host: ${host}
Command: ${command}"

  local response
  if [[ "$API_TYPE" == "anthropic" ]]; then
    response=$(curl -sS --max-time "$TIMEOUT" "$API_URL" \
      -H "x-api-key: $API_KEY" \
      -H "anthropic-version: 2023-06-01" \
      -H "content-type: application/json" \
      -d "$(
        jq -n \
          --arg model "$MODEL" \
          --arg system "$SYSTEM_PROMPT" \
          --arg user "$user_message" \
          --argjson max_tokens "$MAX_TOKENS" \
          --arg tool_name "$TOOL_NAME" \
          --arg tool_desc "$TOOL_DESC" \
          --argjson tool_schema "$TOOL_SCHEMA" \
          '{
            model: $model,
            max_tokens: $max_tokens,
            system: $system,
            tool_choice: {type: "tool", name: $tool_name},
            tools: [{name: $tool_name, description: $tool_desc, input_schema: $tool_schema}],
            messages: [{role: "user", content: $user}]
          }'
      )" 2>&1)

    # Anthropic tool_use: result is in content[].type=="tool_use" -> input
    local tool_json
    tool_json=$(echo "$response" | jq -r '
      .content[]? | select(.type == "tool_use") | .input // empty
    ' 2>/dev/null)
    if [[ -z "$tool_json" || "$tool_json" == "null" ]]; then
      local err
      err=$(echo "$response" | jq -r '.error.message // empty' 2>/dev/null)
      echo "ERROR:${err:-$response}"
      return 1
    fi
    echo "$tool_json"

  elif [[ "$API_TYPE" == "openai" ]]; then
    response=$(curl -sS --max-time "$TIMEOUT" "$API_URL" \
      -H "Authorization: Bearer $API_KEY" \
      -H "content-type: application/json" \
      -d "$(
        jq -n \
          --arg model "$MODEL" \
          --arg system "$SYSTEM_PROMPT" \
          --arg user "$user_message" \
          --argjson max_tokens "$MAX_TOKENS" \
          --arg tool_name "$TOOL_NAME" \
          --arg tool_desc "$TOOL_DESC" \
          --argjson tool_schema "$TOOL_SCHEMA" \
          '{
            model: $model,
            max_tokens: $max_tokens,
            tool_choice: {type: "function", function: {name: $tool_name}},
            tools: [{type: "function", function: {name: $tool_name, description: $tool_desc, parameters: $tool_schema}}],
            messages: [
              {role: "system", content: $system},
              {role: "user", content: $user}
            ]
          }'
      )" 2>&1)

    # OpenAI function calling: result is in choices[0].message.tool_calls[0].function.arguments
    local tool_json
    tool_json=$(echo "$response" | jq -r '
      .choices[0].message.tool_calls[0].function.arguments // empty
    ' 2>/dev/null)
    if [[ -z "$tool_json" || "$tool_json" == "null" ]]; then
      local err
      err=$(echo "$response" | jq -r '.error.message // empty' 2>/dev/null)
      echo "ERROR:${err:-$response}"
      return 1
    fi
    echo "$tool_json"
  else
    echo "ERROR:Unknown API_TYPE: $API_TYPE"
    return 1
  fi
}

# --- Parse LLM decision ---
# Returns: DECISION|RISK|REASON
_parse_decision() {
  local llm_output="$1"

  # llm_output is already JSON from function calling (object or stringified)
  local decision reason risk
  decision=$(echo "$llm_output" | jq -r '.decision // empty' 2>/dev/null)
  reason=$(echo "$llm_output" | jq -r '.reason // "no reason given"' 2>/dev/null)
  risk=$(echo "$llm_output" | jq -r '.risk // "5"' 2>/dev/null)

  if [[ -z "$decision" ]]; then
    # Fallback: try extracting JSON from freeform text (in case model ignored tool_choice)
    local json
    json=$(echo "$llm_output" | grep -oP '\{[^}]+\}' | head -1)
    if [[ -n "$json" ]]; then
      decision=$(echo "$json" | jq -r '.decision // empty' 2>/dev/null)
      reason=$(echo "$json" | jq -r '.reason // "no reason given"' 2>/dev/null)
      risk=$(echo "$json" | jq -r '.risk // "5"' 2>/dev/null)
    fi
  fi

  if [[ "$decision" == "APPROVE" ]]; then
    echo "APPROVE|${risk}|$reason"
  else
    echo "DENY|${risk}|${reason:-Failed to parse LLM response}"
  fi
}

# --- Output redaction filter ---
# General structural patterns - no vendor-specific names needed.
_redact_output() {
  sed -E \
    -e 's/([_-](TOKEN|KEY|SECRET|PASSWORD|PASSWD|CREDENTIAL|AUTH)[[:space:]]*[=:][[:space:]]*["\x27]?)([^"\x27[:space:]}{,]+)/\1[REDACTED]/gi' \
    -e 's/((password|passwd|secret|token|bearer)[[:space:]]*[=:][[:space:]]*["\x27]?)([^"\x27[:space:]}{,]+)/\1[REDACTED]/gi' \
    -e 's/(-----BEGIN [A-Z ]*PRIVATE KEY-----).*/\1 [REDACTED]/g' \
    -e 's/(sk-[A-Za-z0-9_-]{20,})/[REDACTED]/g' \
    -e 's/(eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+)/[REDACTED]/g'
}

# --- Execute SSH with optional redaction ---
_exec_ssh() {
  if [[ "$REDACT" == "true" ]]; then
    "$SSH_BIN" "$@" 2>&1 | _redact_output
    return "${PIPESTATUS[0]}"
  else
    exec "$SSH_BIN" "$@"
  fi
}

# --- Extract destination host from args ---
_extract_destination() {
  local -a opts_with_arg=(-b -c -D -E -e -F -I -i -J -L -l -m -O -o -p -Q -R -S -W -w)
  local skip_next=false

  for arg in "$@"; do
    if $skip_next; then
      skip_next=false
      continue
    fi
    local is_opt_with_arg=false
    for opt in "${opts_with_arg[@]}"; do
      if [[ "$arg" == "$opt" ]]; then
        is_opt_with_arg=true
        skip_next=true
        break
      fi
      if [[ "$arg" == "${opt}"* && ${#arg} -gt 2 ]]; then
        is_opt_with_arg=true
        break
      fi
    done
    $is_opt_with_arg && continue
    [[ "$arg" == -* ]] && continue
    echo "$arg"
    return
  done
}

# --- Main ---
main() {
  # If no arguments, just pass through to ssh (will show usage)
  if [[ $# -eq 0 ]]; then
    exec "$SSH_BIN"
  fi

  local remote_cmd
  remote_cmd="$(_extract_command "$@")"

  # If no remote command (interactive session), block by default
  if [[ -z "$remote_cmd" ]]; then
    echo "ssh-guard: interactive sessions are not permitted through ssh-guard." >&2
    echo "ssh-guard: provide a command: ssh-guard ${destination:-host} 'command'" >&2
    echo "ssh-guard: for interactive access, use ssh directly." >&2
    _log "BLOCKED interactive session attempt: $*"
    exit 1
  fi

  local destination
  destination="$(_extract_destination "$@")"

  _log "REQUEST host=$destination cmd=$remote_cmd"

  # Check passthrough
  if _is_passthrough "$remote_cmd"; then
    _log "PASSTHROUGH cmd=$remote_cmd"
    _exec_ssh "$@"
  fi

  # Validate API key
  if [[ -z "$API_KEY" ]]; then
    echo "ssh-guard: SSH_GUARD_API_KEY is not set. Cannot validate command." >&2
    echo "ssh-guard: Set it in your environment or a .env file." >&2
    exit 1
  fi

  # Call LLM
  local llm_response
  if ! llm_response="$(_call_llm "$remote_cmd" "$destination")"; then
    echo "ssh-guard: LLM call failed: $llm_response" >&2
    _log "ERROR llm_call_failed: $llm_response"
    exit 1
  fi

  local parsed decision risk reason remainder
  parsed="$(_parse_decision "$llm_response")"
  decision="${parsed%%|*}"
  remainder="${parsed#*|}"
  risk="${remainder%%|*}"
  reason="${remainder#*|}"

  if [[ "$decision" == "APPROVE" ]]; then
    # Silent on approve; log only when risk is notable (>= 4)
    if [[ "$risk" -ge 4 ]] 2>/dev/null; then
      _log "APPROVED risk=$risk cmd=$remote_cmd reason=$reason"
    fi
    _exec_ssh "$@"
  else
    _log "DENIED risk=$risk cmd=$remote_cmd reason=$reason"
    echo "ssh-guard: DENIED (risk=$risk) - $reason" >&2
    exit 1
  fi
}

main "$@"
