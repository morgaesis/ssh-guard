# EXAMPLE multi-model fallback chain for guard. NOT the default.
#
# Guard's default is LLM-only evaluation with a single model. This file is an
# opt-in override for deployments whose uptime requirements exceed the SLA of
# a single LLM provider, or that need to defend against provider-specific
# outages.
#
# Load with your service manager, or:
#   set -a; source examples/fallback-models.env; set +a
#   guard server start

# Primary evaluator -- tried first on every command
SSH_GUARD_LLM_MODEL=openai/gpt-5.4-nano

# Optional fallback chain -- comma-separated list
# Tried in order if the primary fails after retries
# Default: empty (no fallback)
# SSH_GUARD_LLM_MODELS=openai/gpt-5.4-nano,meta-llama/llama-4-maverick

# Retries per model before moving to the next fallback
# Default: 2 (total 3 requests per model)
# SSH_GUARD_LLM_RETRIES=2

# The default single-model behavior is sufficient for most deployments.
# Only enable the fallback chain if your uptime requirements exceed the
# single-provider SLA or you are defending against provider-specific outages.
