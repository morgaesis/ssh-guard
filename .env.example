# guard environment configuration
# Copy to .env and fill in required values.
#
# The legacy SSH_GUARD_* variable names are still honored as fallbacks, so
# existing configurations keep working without renaming.

# --- Required ---

# LLM API key for command evaluation. Supports OpenRouter or any OpenAI-compatible endpoint.
GUARD_LLM_API_KEY=
# Or use: OPENROUTER_API_KEY=

# --- Optional (defaults shown) ---

# LLM endpoint URL. GUARD_API_URL is accepted as a legacy alias.
# GUARD_LLM_API_URL=https://openrouter.ai/api/v1/chat/completions

# Model for command evaluation.
# GUARD_LLM_MODEL=openai/gpt-5.4-nano
# Optional fallback chain; when set, it takes precedence over GUARD_LLM_MODEL.
# GUARD_LLM_MODELS=openai/gpt-5.4-nano,meta-llama/llama-4-maverick

# Evaluation mode: readonly, safe, or paranoid.
# GUARD_MODE=readonly

# LLM call timeout in seconds. GUARD_TIMEOUT is accepted as a legacy alias.
# GUARD_LLM_TIMEOUT=30

# Shared token for TCP clients.
# GUARD_AUTH_TOKEN=
# Separate token for TCP admin RPCs such as guard grant/status.
# GUARD_ADMIN_TOKEN=

# Learn static allow rules from repeated low-risk LLM approvals.
# GUARD_LEARN_RULES=false
# GUARD_LEARN_MIN_APPROVALS=2
# GUARD_LEARN_MAX_RISK=2
# GUARD_LEARN_SHIMS=suggest

# Path to additive prompt file (appended to the base prompt).
# GUARD_PROMPT_APPEND=

# Consequence gating: off (default) or consequence. When enabled, LLM-approved
# commands are routed by reversibility (reversible runs now, recoverable runs
# behind an auto-revert envelope, irreversible is held for operator approval).
# Requires a Unix-socket listener (incompatible with --tcp-port).
# GUARD_GATE=off

# Path to the verb catalog YAML (operator-defined typed operations agents call
# via `guard verb`). Hot-reloaded on change. See examples/verbs.yaml.
# GUARD_VERBS=

# Secret backend: pass, env, or local (auto-detected if not set).
# GUARD_BACKEND=

# GPG recipient for secret encryption.
# GUARD_GPG_RECIPIENT=
