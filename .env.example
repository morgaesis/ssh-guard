# ssh-guard configuration
# Copy to .env and fill in your values

# Required: API key for the LLM endpoint
# Falls back to OPENROUTER_API_KEY if set
SSH_GUARD_API_KEY=

# LLM endpoint (default: OpenRouter)
# SSH_GUARD_API_URL=https://openrouter.ai/api/v1/chat/completions

# Model (default: google/gemini-2.0-flash-001)
# SSH_GUARD_MODEL=google/gemini-2.0-flash-001

# API type: "openai" or "anthropic" (default: openai)
# SSH_GUARD_API_TYPE=openai

# Policy mode: "readonly", "paranoid", or "safe" (default: readonly)
# SSH_GUARD_MODE=readonly

# Path to real ssh binary (default: /usr/bin/ssh)
# SSH_GUARD_SSH_BIN=/usr/bin/ssh

# Log file for audit trail (default: none)
# SSH_GUARD_LOG=/var/log/ssh-guard.log

# Redact secrets from command output (default: true)
# SSH_GUARD_REDACT=true

# Commands to always allow without LLM check (comma-separated)
# SSH_GUARD_PASSTHROUGH=uptime,hostname,whoami

# Custom system prompt (overrides mode prompts)
# SSH_GUARD_PROMPT=

# LLM call timeout in seconds (default: 30)
# SSH_GUARD_TIMEOUT=30

# Max response tokens (default: 512)
# SSH_GUARD_MAX_TOKENS=512
