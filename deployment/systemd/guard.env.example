# guard systemd service environment
# Install to /etc/default/guard

# --- Required ---

# LLM API key for command evaluation.
SSH_GUARD_LLM_API_KEY=

# --- Optional (defaults shown) ---

# LLM endpoint URL.
# SSH_GUARD_API_URL=https://openrouter.ai/api/v1/chat/completions

# Primary model for command evaluation.
# SSH_GUARD_LLM_MODEL=openai/gpt-5.4-nano

# Optional fallback chain (comma-separated). When set, takes precedence over
# SSH_GUARD_LLM_MODEL above because a chain is an explicit opt-in to
# multi-model evaluation.
# SSH_GUARD_LLM_MODELS=openai/gpt-5.4-nano,meta-llama/llama-4-maverick

# Evaluation mode: default, safe, or paranoid.
# SSH_GUARD_MODE=default

# LLM call timeout in seconds.
# SSH_GUARD_TIMEOUT=10

# Path to additive prompt file (appended to the base prompt).
# SSH_GUARD_PROMPT_APPEND=
