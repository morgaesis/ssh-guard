# guard systemd service environment
# Install to /etc/default/guard

# --- Required ---

# LLM API key for command evaluation.
GUARD_LLM_API_KEY=

# --- Optional (defaults shown) ---

# Emit startup paths and runtime configuration to the systemd journal.
RUST_LOG=info

# LLM endpoint URL. GUARD_API_URL is accepted as a legacy alias.
# GUARD_LLM_API_URL=https://openrouter.ai/api/v1/chat/completions

# Primary model for command evaluation.
# GUARD_LLM_MODEL=openai/gpt-5.4-nano

# Optional fallback chain (comma-separated). When set, takes precedence over
# GUARD_LLM_MODEL above because a chain is an explicit opt-in to
# multi-model evaluation.
# GUARD_LLM_MODELS=openai/gpt-5.4-nano,meta-llama/llama-4-maverick

# Evaluation mode: readonly, safe, or paranoid.
# GUARD_MODE=readonly

# LLM call timeout in seconds. GUARD_TIMEOUT is accepted as a legacy alias.
# GUARD_LLM_TIMEOUT=30

# Shared token for TCP clients. Usually only needed for TCP loopback deployments.
# GUARD_AUTH_TOKEN=
# Separate token for TCP admin RPCs. Usually only needed for TCP loopback deployments.
# GUARD_ADMIN_TOKEN=

# Learned static allow rules for repeated low-risk approvals.
# GUARD_LEARN_RULES=false
# GUARD_LEARN_MIN_APPROVALS=2
# GUARD_LEARN_MAX_RISK=2
# GUARD_LEARN_SHIMS=suggest

# Path to additive prompt file (appended to the base prompt).
# GUARD_PROMPT_APPEND=

# Enable deterministic pre-LLM checks: executable-exists on PATH and
# credential-disclosure pattern deny. These are coarse and can over-match
# (they block any command containing the `env` token). Leave off to let the
# LLM be the sole decision authority; turn on for hosts where LLM cost or
# latency dominates over false positives.
# GUARD_PREFLIGHT=false

# In-memory cache of LLM decisions. A command approved once returns from
# cache on subsequent requests within the TTL without another LLM call.
# Cache is cleared on daemon restart and on any prompt file change that
# forces a new Evaluator. Set GUARD_CACHE=false to disable.
# GUARD_CACHE=true
# GUARD_CACHE_CAPACITY=1024
# GUARD_CACHE_TTL=3600

# Admin RPCs (session grant/revoke/list, full status snapshot) are
# restricted to the daemon's own UID. There is no env var or token to
# elevate a client.
