FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-client \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create agent user
RUN useradd -m -s /bin/false agent

# Install guard binary
COPY ssh-guard /usr/local/bin/ssh-guard
RUN chmod 755 /usr/local/bin/ssh-guard

# Client config
RUN mkdir -p /home/agent/.config/ssh-guard /home/agent/.guard /home/agent/.ssh
COPY client.yaml /home/agent/.config/ssh-guard/client.yaml

RUN chown -R agent:agent /home/agent

COPY entrypoint-agent.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER agent
WORKDIR /home/agent

CMD ["/entrypoint.sh"]
